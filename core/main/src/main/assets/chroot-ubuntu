#!/bin/bash
#
# Chroot Environment Script - Proper Implementation
#

ROOTFS_DIR="/data/data/com.rk.terminal.debug/files/usr"

echo -e "\e[35;1m[*] \e[0mStarting Chroot Ubuntu Environment\e[0m"

# Check if rootfs exists
if [ ! -d "$ROOTFS_DIR" ]; then
    echo -e "\e[31;1m[✗] \e[0mRootFS not found at $ROOTFS_DIR\e[0m"
    echo -e "\e[33;1m[i] \e[0mPlease install Ubuntu environment first\e[0m"
    exit 1
fi

# Function to check if we have root privileges
check_root() {
    if [ "$(id -u)" -eq 0 ]; then
        return 0
    else
        return 1
    fi
}

# Function to try getting root via su
try_su() {
    if command -v su >/dev/null 2>&1; then
        echo -e "\e[33;1m[*] \e[0mTrying to get root via su...\e[0m"
        su -c "$0 $*"
        return $?
    else
        return 1
    fi
}

# Function to try using Shizuku for privileged operations
try_shizuku() {
    # Check if we can use Shizuku for mounting
    echo -e "\e[33;1m[*] \e[0mTrying Shizuku for privileged operations...\e[0m"
    
    # Create a script that Shizuku can execute
    cat > /tmp/chroot_setup.sh << 'EOF'
#!/system/bin/sh

ROOTFS_DIR="/data/data/com.rk.terminal.debug/files/usr"

# Create mount points
mkdir -p "$ROOTFS_DIR"/{proc,sys,dev/pts,tmp}

# Mount essential filesystems
mount -t proc proc "$ROOTFS_DIR/proc" 2>/dev/null
mount --rbind /sys "$ROOTFS_DIR/sys" 2>/dev/null  
mount --rbind /dev "$ROOTFS_DIR/dev" 2>/dev/null
mount -t devpts devpts "$ROOTFS_DIR/dev/pts" 2>/dev/null

# Copy network configuration
cp /etc/resolv.conf "$ROOTFS_DIR/etc/resolv.conf" 2>/dev/null

echo "Chroot setup completed"
EOF

    chmod +x /tmp/chroot_setup.sh
    
    # Try to execute via Shizuku (this would need to be called from the app)
    if [ "$SHIZUKU_AVAILABLE" = "1" ]; then
        /tmp/chroot_setup.sh
        return $?
    else
        return 1
    fi
}

# Main execution logic
if ! check_root; then
    echo -e "\e[33;1m[*] \e[0mChroot requires root privileges, attempting to obtain them...\e[0m"
    
    # Try su first
    if try_su; then
        exit 0
    fi
    
    # Try Shizuku if su fails
    if try_shizuku; then
        echo -e "\e[32;1m[✓] \e[0mChroot setup completed via Shizuku\e[0m"
    else
        echo -e "\e[31;1m[✗] \e[0mCannot obtain root privileges\e[0m"
        echo -e "\e[33;1m[i] \e[0mEnsure device is rooted, Shizuku is running, or grant su permission\e[0m"
        exit 1
    fi
fi

# We have root privileges, proceed with chroot setup
echo -e "\e[33;1m[*] \e[0mSetting up chroot environment with root privileges...\e[0m"

# Create mount points
mkdir -p "$ROOTFS_DIR"/{proc,sys,dev/pts,tmp}

# Mount essential filesystems with proper options
echo -e "\e[33;1m[*] \e[0mMounting filesystems...\e[0m"

# Mount /proc
if ! mountpoint -q "$ROOTFS_DIR/proc"; then
    mount -t proc proc "$ROOTFS_DIR/proc"
    if [ $? -eq 0 ]; then
        echo -e "\e[32;1m[✓] \e[0m/proc mounted\e[0m"
    else
        echo -e "\e[31;1m[✗] \e[0mFailed to mount /proc\e[0m"
    fi
fi

# Mount /sys with rbind
if ! mountpoint -q "$ROOTFS_DIR/sys"; then
    mount --rbind /sys "$ROOTFS_DIR/sys"
    if [ $? -eq 0 ]; then
        echo -e "\e[32;1m[✓] \e[0m/sys mounted\e[0m"
    else
        echo -e "\e[31;1m[✗] \e[0mFailed to mount /sys\e[0m"
    fi
fi

# Mount /dev with rbind
if ! mountpoint -q "$ROOTFS_DIR/dev"; then
    mount --rbind /dev "$ROOTFS_DIR/dev"
    if [ $? -eq 0 ]; then
        echo -e "\e[32;1m[✓] \e[0m/dev mounted\e[0m"
    else
        echo -e "\e[31;1m[✗] \e[0mFailed to mount /dev\e[0m"
    fi
fi

# Mount /dev/pts
if ! mountpoint -q "$ROOTFS_DIR/dev/pts"; then
    mount -t devpts devpts "$ROOTFS_DIR/dev/pts"
    if [ $? -eq 0 ]; then
        echo -e "\e[32;1m[✓] \e[0m/dev/pts mounted\e[0m"
    else
        echo -e "\e[31;1m[✗] \e[0mFailed to mount /dev/pts\e[0m"
    fi
fi

# Copy network configuration
cp /etc/resolv.conf "$ROOTFS_DIR/etc/resolv.conf" 2>/dev/null

# Set up chroot environment variables
echo "CHROOT_MODE=1" > "$ROOTFS_DIR/etc/environment"
echo "export CHROOT_MODE=1" >> "$ROOTFS_DIR/root/.bashrc"

# Set environment variables for chroot
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
export HOME="/root"
export USER="root"
export LOGNAME="root"
export SHELL="/bin/bash"
export TERM="${TERM:-xterm-256color}"
export CHROOT_MODE=1

echo -e "\e[32;1m[✓] \e[0mChroot environment ready\e[0m"
echo -e "\e[36;1m[i] \e[0mEntering Ubuntu chroot...\e[0m"

# Cleanup function
cleanup() {
    echo -e "\e[33;1m[*] \e[0mCleaning up chroot session...\e[0m"
    # Only unmount if we're the last chroot session
    if [ $(pgrep -f "chroot.*$ROOTFS_DIR" | wc -l) -le 1 ]; then
        umount "$ROOTFS_DIR/dev/pts" 2>/dev/null
        umount "$ROOTFS_DIR/dev" 2>/dev/null
        umount "$ROOTFS_DIR/sys" 2>/dev/null
        umount "$ROOTFS_DIR/proc" 2>/dev/null
        echo -e "\e[32;1m[✓] \e[0mChroot mounts cleaned up\e[0m"
    fi
}

trap cleanup EXIT

# Enter chroot with proper environment
chroot "$ROOTFS_DIR" /bin/bash -c "
export CHROOT_MODE=1
export PS1='\[\e[31m\][CHROOT]\[\e[0m\] \[\e[38;5;46m\]\u\[\033[39m\]@ubuntu \[\033[39m\]\w \[\033[0m\]\$ '
cd /root
exec /bin/bash -l
"

echo -e "\e[32;1m[✓] \e[0mChroot session ended\e[0m"
